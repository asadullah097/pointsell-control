{
  "name": "pointsell-control",
  "version": "1.0.0",
  "description": "PointSell Control Panel — license server, tenant onboarding, update server",
  "private": true,
  "scripts": {
    "build:ui": "cd ui && npm install && npm run build",
    "build": "npm run build:ui && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "ui:dev": "cd ui && npm run dev",
    "migration:run": "typeorm migration:run -d dist/config/typeorm.config.js",
    "migration:generate": "typeorm migration:generate -d dist/config/typeorm.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.0.0"
  }
}
