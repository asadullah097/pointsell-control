# ─── PointSell Control Panel ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pointsell_control
DB_USER=postgres
DB_PASS=secret

# ─── Auth (admin dashboard JWT) ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars

# ─── CORS (control panel UI domain + public landing page) ───────────────────
# Comma-separated. Must include the landing page's origin — it calls
# POST /api/signup-requests directly from the browser.
ALLOWED_ORIGINS=https://control.pointsell.app,https://tijarah.app

# ─── Private key path (see keys/README.txt) ──────────────────────────────────
# By default: ./keys/private.pem
# This file must NEVER be committed to git.

# ─── Admin credentials (first admin user) ────────────────────────────────────
ADMIN_EMAIL=admin@pointsell.app
ADMIN_PASSWORD=CHANGE_ME

# ─── Cloud POS integration (SaaS mode only) ──────────────────────────────────
# When set, TenantsController proxies all CRUD and metrics through the POS API.
# Leave blank for local-license-only mode (no cloud tenant management).
CLOUD_POS_API_URL=https://api.pointsell.app
# Must match CONTROL_PANEL_API_KEY in nestjs-pos .env
CONTROL_PANEL_API_KEY=CHANGE_ME_min_32_chars

# ─── Signup requests (landing page → admin approval → welcome email) ────────
# Trial length granted when an admin approves a request without overriding trialDays.
DEFAULT_TRIAL_DAYS=14
# Where the welcome email's "Log in to PointSell" button points.
FRONTEND_LOGIN_URL=https://app.pointsell.app/login

# ─── SMTP (welcome / rejection emails) ───────────────────────────────────────
# Leave blank in dev — emails are logged to the console instead of sent.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
SMTP_FROM="PointSell <no-reply@pointsell.app>"
